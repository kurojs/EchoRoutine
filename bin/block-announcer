#!/usr/bin/env bash
set -euo pipefail

# Block Announcer — triggered by systemd timer at each schedule block time.
# Launches OpenCode in headless mode. The AI agent checks the actual system
# time, determines the active block, generates a motivational message, and
# outputs it via ElevenLabs TTS + KDE notification.
#
# Dependencies:
#   - OpenCode CLI (https://opencode.ai)
#   - elevenlabs-mcp-tts (https://github.com/kurojs/elevenlabs-mcp-tts)
#   - notify-send (libnotify)
#   - systemd (user mode)
#
# Config:
#   ~/.config/echoroutine/schedule.txt — your daily schedule

# Priority: echoutine (TUI standard) → schedule-announcer (legacy)
if [ -d "${HOME}/.config/echoroutine" ]; then
    CONFIG_DIR="${HOME}/.config/echoroutine"
else
    CONFIG_DIR="${HOME}/.config/schedule-announcer"
fi
SCHEDULE_FILE="${CONFIG_DIR}/schedule.txt"
LANG_FILE="${CONFIG_DIR}/language.txt"
STAMP_FILE="/tmp/schedule-announcer-last"
LOCK_FILE="/tmp/schedule-announcer.lock"

CURRENT_HOUR=$(date +%H)
CURRENT_MIN=$(date +%M)
CURRENT_TIME="${CURRENT_HOUR}:${CURRENT_MIN}"

# --- Language ---
# Read language setting — any language ElevenLabs supports.
# Default: Spanish. Examples: English, Japanese, French, German, Korean, Chinese...
ANNOUNCE_LANG="Spanish"
if [ -f "${LANG_FILE}" ]; then
    LANG_CONTENT=$(head -1 "${LANG_FILE}" | xargs)
    if [ -n "${LANG_CONTENT}" ]; then
        ANNOUNCE_LANG="${LANG_CONTENT}"
    fi
fi

# --- Stamp dedup with flock ---
# Prevents re-announcing the same minute (defense against race conditions)
(
    flock -n 9 || exit 0

    if [ -f "${STAMP_FILE}" ]; then
        LAST=$(cat "${STAMP_FILE}")
        if [ "${LAST}" = "${CURRENT_TIME}" ]; then
            exit 0
        fi
    fi

    # --- Read block times from schedule.txt ---
    if [ ! -f "${SCHEDULE_FILE}" ]; then
        echo "schedule.txt not found at ${SCHEDULE_FILE}" >&2
        notify-send --urgency=critical --expire-time=10000 \
            "⚠️ Schedule Announcer" "schedule.txt no encontrado en ${SCHEDULE_FILE}"
        exit 1
    fi

    # Extract HH:MM from schedule.txt lines like "08:00 - Activity"
    BLOCK_TIMES=$(grep -oP '^\s*\d{2}:\d{2}' "${SCHEDULE_FILE}" | tr '\n' ' ')

    if [ -z "${BLOCK_TIMES}" ]; then
        echo "No valid block times found in ${SCHEDULE_FILE}" >&2
        notify-send --urgency=critical --expire-time=10000 \
            "⚠️ Schedule Announcer" "No se encontraron horarios válidos en schedule.txt"
        exit 1
    fi

    MATCH=0
    for t in ${BLOCK_TIMES}; do
        if [ "${t}" = "${CURRENT_TIME}" ]; then
            MATCH=1
            break
        fi
    done

    if [ "${MATCH}" = "0" ]; then
        exit 0
    fi

    # Mark this minute as announced
    echo "${CURRENT_TIME}" > "${STAMP_FILE}"

    # --- Launch OpenCode AI agent ---
    if ! command -v opencode &>/dev/null; then
        notify-send --urgency=normal --expire-time=8000 \
            "⛩️ Schedule: ${CURRENT_TIME}" \
            "¡Hora del bloque! (OpenCode no disponible — instalalo para mensajes AI + TTS)"
        exit 1
    fi

    # Build the prompt with the selected language
    PROMPT=$(cat <<PROMPT_EOF
Block Announcer — schedule change detected at ${CURRENT_TIME}.

1. Check the actual system time with: date '+%H:%M' and day of week with: date '+%u' (1=Mon..7=Sun).
2. Using the schedule file provided, determine which block corresponds to the current time. If it's 13:00, Mon/Wed/Fri (days 1,3,5) is fitness/break, other days is programming.
3. If the current time does NOT match any block exactly, respond with only: NO_BLOCK
4. If it matches, generate a SHORT motivational message (1-2 sentences) in ${ANNOUNCE_LANG} for that specific block. It MUST be creative, unique every time, with personality. No emojis.
5. Use the elevenlabs-tts_text_to_speech MCP tool to speak the message aloud with voice_id h3KZVBOooxHZiKRxnsdE.
6. Run: notify-send --urgency=normal --expire-time=8000 --icon=face-smile '⛩️ BLOCK_NAME_HERE' 'MESSAGE_HERE'
7. Reply only: LISTO
PROMPT_EOF
)

    if ! opencode run \
        --dangerously-skip-permissions \
        --file "${SCHEDULE_FILE}" \
        --title "block-announcer ${CURRENT_TIME}" \
        "${PROMPT}"; then

        # Fallback: OpenCode failed, send a basic notification
        notify-send --urgency=normal --expire-time=8000 \
            "⛩️ Schedule: ${CURRENT_TIME}" \
            "¡Hora del bloque! (AI no respondió — revisá tu conexión o API key)"
        exit 1
    fi

) 9>"${LOCK_FILE}"
